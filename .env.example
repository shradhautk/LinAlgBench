# API Keys for LinAlg-Bench pipeline
# Copy this file to .env and fill in your actual keys
# DO NOT commit .env with real keys to version control

# OpenRouter (for Stage 1: inference on open-source models)
# Get your key from https://openrouter.ai/settings
OPENROUTER_API_KEY=your-openrouter-key-here

# OpenAI (for Stage 1: inference on GPT-4o, GPT-5.2, OpenAI-o1)
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Gemini (for Stage 2-3: judge and validator)
# Get your key from https://aistudio.google.com/app/apikey
# Primary key
GEMINI_API_KEY=your-gemini-key-here
# Backup key (optional)
GEMINI_API_KEY2=your-gemini-backup-key-here